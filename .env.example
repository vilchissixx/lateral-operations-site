NEWSLETTER_PROVIDER=mailchimp
MAILCHIMP_API_KEY=replace-with-mailchimp-api-key
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_AUDIENCE_ID=replace-with-audience-id
